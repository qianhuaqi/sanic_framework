APP_NAME={{ app_name }}
PROJECT_NAME={{ project_name }}
HOST=0.0.0.0
PORT={{ port }}
WORKERS=1
DEBUG=false
LANGUAGE=zh-CN
LOCALE_DIR=app/language

# [AUTH]
ENABLE_AUTH={{ "true" if enable_auth else "false" }}
ENABLE_SIGNING={{ "true" if enable_signing else "false" }}
ENABLE_I18N={{ "true" if enable_i18n else "false" }}
ENABLE_RESPONSE_CACHE={{ "true" if enable_response_cache else "false" }}
AUTH_SECRET=change-me
AUTH_WHITE_IP_LIST=
SIGNING_SECRET=change-me
CRYPT_RESPONSE_SECRET=change-me
CRYPT_PARAMS_SECRET=change-me

# [CORS]
CORS_ENABLED=false
CORS_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Request-ID
CORS_ALLOW_CREDENTIALS=false
CORS_MAX_AGE=86400

# [LOG]
LOG_TO_FILE=true
LOG_LEVEL=INFO
LOG_PATH=runtime/logs
LOG_FILE=app.log
LOG_FORMATTER=%(asctime)s [%(levelname)s] [%(name)s] %(message)s
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=7

# [MYSQL]
MYSQL_ENABLED={{ "true" if "mysql" in databases else "false" }}
{% if "mysql" in databases %}
MYSQL_MASTER_HOST=localhost
MYSQL_MASTER_PORT=3306
MYSQL_MASTER_USER=app
MYSQL_MASTER_PASSWORD=change-me
MYSQL_MASTER_DATABASE={{ app_name }}
MYSQL_SLAVES=
MYSQL_POOL_SIZE=5
MYSQL_POOL_RECYCLE=3600
{% endif %}

# [REDIS]
REDIS_ENABLED={{ "true" if "redis" in databases else "false" }}
{% if "redis" in databases %}
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_EXPIRE=3600
REDIS_PREFIX=sanic_
REDIS_IDLE_TIMEOUT=600
REDIS_SENTINEL_ENABLED=false
REDIS_MASTER_NAME=mymaster
REDIS_SENTINELS=
{% endif %}

# [MONGO]
MONGO_ENABLED={{ "true" if "mongo" in databases else "false" }}
{% if "mongo" in databases %}
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_DATABASE={{ app_name }}
{% endif %}

# [META]
SQLITE_ENABLED=false
