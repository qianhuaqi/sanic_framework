APP_NAME=sanic-template
PROJECT_NAME=sanic-template
HOST=0.0.0.0
PORT=8000
WORKERS=1
DEBUG=false
LANGUAGE=zh-CN
LOCALE_DIR=app/language

# [AUTH]
ENABLE_AUTH=true
ENABLE_SIGNING=true
ENABLE_I18N=true
ENABLE_RESPONSE_CACHE=true
AUTH_SECRET=change-me
AUTH_WHITE_IP_LIST=
SIGNING_SECRET=change-me
CRYPT_RESPONSE_SECRET=change-me
CRYPT_PARAMS_SECRET=change-me

# [CORS]
CORS_ENABLED=false
CORS_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Request-ID
CORS_ALLOW_CREDENTIALS=false
CORS_MAX_AGE=86400

# [LOG]
LOG_TO_FILE=true
LOG_LEVEL=INFO
LOG_PATH=runtime/logs
LOG_FILE=app.log
LOG_FORMATTER=%(asctime)s [%(levelname)s] [%(name)s] %(message)s
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=7

# [MYSQL]
MYSQL_ENABLED=false
MYSQL_MASTER_HOST=localhost
MYSQL_MASTER_PORT=3306
MYSQL_MASTER_USER=app
MYSQL_MASTER_PASSWORD=change-me
MYSQL_MASTER_DATABASE=app
MYSQL_SLAVES=
MYSQL_POOL_SIZE=5
MYSQL_POOL_RECYCLE=3600

# [REDIS]
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_EXPIRE=3600
REDIS_PREFIX=sanic_
REDIS_IDLE_TIMEOUT=600
REDIS_SENTINEL_ENABLED=false
REDIS_MASTER_NAME=mymaster
REDIS_SENTINELS=

# [MONGO]
MONGO_ENABLED=false
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_DATABASE=app

# [META]
SQLITE_ENABLED=false
