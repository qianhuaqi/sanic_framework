[build-system]
requires = ["setuptools>=68", "wheel"]
build-backend = "setuptools.build_meta"

[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "{{ project_name }} LingShu application"
readme = "README.md"
requires-python = ">=3.10,<3.15"
dependencies = [
  "lingshu-framework>=0.2,<0.3",
]

[project.optional-dependencies]
dev = []

[tool.setuptools.packages.find]
where = ["."]
include = ["app*", "config*"]
